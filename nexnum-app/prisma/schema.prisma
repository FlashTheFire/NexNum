generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  passwordHash            String                   @map("password_hash")
  name                    String
  googleId                String?                  @unique @map("google_id")
  githubId                String?                  @unique @map("github_id")
  twitterId               String?                  @unique @map("twitter_id")
  discordId               String?                  @unique @map("discord_id")
  facebookId              String?                  @unique @map("facebook_id")
  telegramId              String?                  @unique @map("telegram_id")
  image                   String?
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  role                    Role                     @default(USER)
  isBanned                Boolean                  @default(false) @map("is_banned")
  emailVerified           DateTime?                @map("email_verified")
  tokenVersion            Int                      @default(1) @map("token_version")
  preferredCurrency       String                   @default("USD") @map("preferred_currency")
  twoFactorEnabled        Boolean                  @default(false)
  twoFactorSecret         String?
  twoFactorBackupCodes    String[]                 @default([])
  apiKeys                 ApiKey[]
  auditLogs               AuditLog[]
  couponRedemptions       CouponRedemption[]
  referrerCoupons         Coupon[]                 @relation("ReferrerCoupons")
  emailVerificationTokens EmailVerificationToken[]
  notificationPreferences NotificationPreferences?
  notifications           Notification[]
  numbers                 Number[]
  reservations            OfferReservation[]
  passwordResets          PasswordReset[]
  purchaseOrders          PurchaseOrder[]
  pushSubscriptions       PushSubscription[]
  verificationAttempts    VerificationAttempt[]    @relation("VerificationAttemptUser")
  wallet                  Wallet?
  webhooks                Webhook[]
  favorites               UserFavorite[]

  @@map("users")
}

model UserFavorite {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String
  value       String
  displayName String   @map("display_name")
  iconUrl     String?  @map("icon_url")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, value])
  @@index([userId, type])
  @@map("user_favorites")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model NotificationPreferences {
  id           String  @id @default(uuid())
  userId       String  @unique @map("user_id")
  emailEnabled Boolean @default(true) @map("email_enabled")
  pushEnabled  Boolean @default(true) @map("push_enabled")
  smsEnabled   Boolean @default(false) @map("sms_enabled")
  smsReceived  Boolean @default(true) @map("sms_received")
  promotions   Boolean @default(true)
  billing      Boolean @default(true)
  security     Boolean @default(true)
  system       Boolean @default(true)
  soundEnabled Boolean @default(true) @map("sound_enabled")
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Wallet {
  id               String              @id @default(uuid())
  userId           String              @unique @map("user_id")
  balance          Decimal             @default(0.00) @db.Decimal(18, 8)
  reserved         Decimal             @default(0.00) @db.Decimal(18, 8)
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @default(now()) @updatedAt @map("updated_at")
  /// Running algebraic sum of ALL committed wallet_transactions.amount values.
  /// Maintained by WalletService after every committed ledger event.
  /// The Sentinel compares balance against (ledgerChecksum + delta-since-checkpoint).
  ledgerChecksum   Decimal             @default(0.00) @map("ledger_checksum") @db.Decimal(18, 8)
  /// UTC timestamp of the last ledgerChecksum update.
  /// Sentinel only aggregates transactions created AFTER this timestamp.
  ledgerChecksumAt DateTime            @default(now()) @map("ledger_checksum_at")
  balanceSnapshot  Json?               @map("balance_snapshot")
  transactions     WalletTransaction[]
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model WalletTransaction {
  id               String   @id @default(uuid())
  walletId         String   @map("wallet_id")
  amount           Decimal  @db.Decimal(18, 8)
  type             String
  description      String?
  idempotencyKey   String?  @unique @map("idempotency_key")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  currencySnapshot Json?    @map("currency_snapshot")
  wallet           Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

model PurchaseOrder {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  serviceName    String   @map("service_name")
  countryName    String   @map("country_name")
  amount         Decimal  @db.Decimal(8, 2)
  status         String
  provider       String?
  activationId   String?  @map("activation_id")
  idempotencyKey String?  @unique @map("idempotency_key")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
  @@index([userId])
  @@map("purchase_orders")
}

model Number {
  id                  String       @id @default(uuid())
  phoneNumber         String       @map("phone_number")
  phoneCountryCode    String?      @map("phone_country_code")
  phoneNationalNumber String?      @map("phone_national_number")
  countryCode         String       @map("country_code")
  countryName         String?      @map("country_name")
  countryIconUrl      String?      @map("country_icon_url")
  serviceName         String?      @map("service_name")
  serviceCode         String?      @map("service_code")
  serviceIconUrl      String?      @map("service_icon_url")
  price               Decimal      @db.Decimal(8, 2)
  providerCost        Decimal      @default(0.0) @map("provider_cost") @db.Decimal(8, 4)
  profit              Decimal      @default(0.0) @db.Decimal(8, 4)
  status              String       @default("available")
  ownerId             String?      @map("owner_id")
  activationId        String?      @map("activation_id")
  provider            String?
  idempotencyKey      String?      @unique @map("idempotency_key")
  expiresAt           DateTime?    @map("expires_at")
  purchasedAt         DateTime?    @map("purchased_at")
  pollCount           Int          @default(0) @map("poll_count")
  nextPollAt          DateTime?    @default(now()) @map("next_poll_at")
  lastPolledAt        DateTime?    @map("last_polled_at")
  errorCount          Int          @default(0) @map("error_count")
  lastError           String?      @map("last_error")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime?    @updatedAt @map("updated_at")
  owner               User?        @relation(fields: [ownerId], references: [id])
  smsMessages         SmsMessage[]

  @@index([ownerId])
  @@index([status])
  @@index([status, createdAt])
  @@index([ownerId, status])
  @@index([provider, status])
  @@index([expiresAt])
  @@map("numbers")
}

model SmsMessage {
  id            String   @id @default(uuid())
  numberId      String   @map("number_id")
  sender        String?
  content       String?
  code          String?
  receivedAt    DateTime @default(now()) @map("received_at")
  provider      String?
  rawPayload    Json?    @map("raw_payload")
  extractedCode String?  @map("extracted_code")
  confidence    Decimal? @db.Decimal(3, 2)
  number        Number   @relation(fields: [numberId], references: [id], onDelete: Cascade)

  @@index([numberId])
  @@index([provider])
  @@map("sms_messages")
}

model AuditLog {
  id           String   @default(uuid())
  userId       String?  @map("user_id")
  action       String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  metadata     Json?
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([id, createdAt])
  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

model ServiceLookup {
  serviceId   Int     @id @default(autoincrement()) @map("id")
  serviceCode String  @unique @map("service_code")
  serviceName String  @map("name")
  serviceIcon String? @map("icon_url")

  @@map("service_lookups")
}

model CountryLookup {
  countryId   Int     @id @default(autoincrement()) @map("id")
  countryCode String  @unique @map("country_code")
  countryName String  @map("name")
  countryIcon String? @map("flag_url")

  @@map("country_lookups")
}

model Provider {
  id                 String               @id @default(uuid())
  name               String               @unique
  displayName        String               @map("display_name")
  description        String?
  logoUrl            String?              @map("logo_url")
  websiteUrl         String?              @map("website_url")
  apiBaseUrl         String               @map("api_base_url")
  authType           String               @default("bearer")
  providerType       String               @default("rest") @map("provider_type")
  authKey            String?              @map("auth_key")
  authHeader         String?              @map("auth_header")
  authQueryParam     String?              @map("auth_query_param")
  endpoints          Json
  mappings           Json
  priceMultiplier    Decimal              @default(1.0) @map("price_multiplier") @db.Decimal(5, 2)
  fixedMarkup        Decimal              @default(0.0) @map("fixed_markup") @db.Decimal(18, 8)
  currency           String               @default("USD")
  normalizationMode  String               @default("AUTO") @map("normalization_mode")
  normalizationRate  Decimal?             @map("normalization_rate") @db.Decimal(18, 8)
  apiPair            String?              @map("api_pair")
  depositSpent       Decimal?             @map("deposit_spent") @db.Decimal(18, 8)
  depositReceived    Decimal?             @map("deposit_received") @db.Decimal(18, 8)
  depositCurrency    String               @default("USD") @map("deposit_currency")
  balance            Decimal              @default(0.0) @db.Decimal(10, 2)
  lowBalanceAlert    Decimal              @default(10.0) @map("low_balance_alert") @db.Decimal(10, 2)
  lastBalanceSync    DateTime?            @map("last_balance_sync")
  successRate        Decimal              @default(100.0) @map("success_rate") @db.Decimal(5, 2)
  totalOrders        Int                  @default(0) @map("total_orders")
  useGlobalSync      Boolean              @default(false) @map("use_global_sync")
  priority           Int                  @default(0)
  lastSyncAt         DateTime?            @map("last_sync_at")
  syncStatus         String?              @map("sync_status")
  count              Int                  @default(0) @map("sync_count")
  lastMetadataSyncAt DateTime?            @map("last_metadata_sync_at")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  isActive           Boolean              @default(false) @map("is_active")
  syncBufferPercent  Decimal              @default(0.0) @map("sync_buffer_percent") @db.Decimal(5, 2)
  countries          ProviderCountry[]
  healthLogs         ProviderHealthLog[]
  services           ProviderService[]
  testResults        ProviderTestResult[]

  @@index([isActive])
  @@index([priority])
  @@index([isActive, priority])
  @@map("providers")
}

model ProviderCountry {
  id         String   @id @default(uuid())
  providerId String   @map("provider_id")
  externalId String   @map("external_id")
  code       String
  name       String
  flagUrl    String?  @map("flag_url")
  isActive   Boolean  @default(true) @map("is_active")
  lastSyncAt DateTime @default(now()) @map("last_sync_at")
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, externalId])
  @@index([providerId])
  @@index([code])
  @@map("provider_countries")
}

model ProviderService {
  id         String   @id @default(uuid())
  providerId String   @map("provider_id")
  externalId String   @map("external_id")
  code       String
  name       String
  iconUrl    String?  @map("icon_url")
  isActive   Boolean  @default(true) @map("is_active")
  lastSyncAt DateTime @default(now()) @map("last_sync_at")
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, externalId])
  @@index([providerId])
  @@index([code])
  @@map("provider_services")
}

model ProviderTestResult {
  id           String   @id @default(uuid())
  providerId   String   @map("provider_id")
  action       String
  success      Boolean
  httpStatus   Int?     @map("http_status")
  responseTime Int?     @map("response_time")
  requestUrl   String?  @map("request_url")
  responseData String?  @map("response_data")
  error        String?
  testedAt     DateTime @default(now()) @map("tested_at")
  provider     Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_test_results")
}

model ProviderHealthLog {
  id          String   @id @default(uuid())
  providerId  String   @map("provider_id")
  status      String
  successRate Decimal  @db.Decimal(5, 2)
  avgLatency  Int
  errorCount  Int      @default(0)
  checkedAt   DateTime @default(now()) @map("checked_at")
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, checkedAt])
  @@map("provider_health_logs")
}

model WebhookEvent {
  id             String    @id @default(uuid())
  provider       String
  eventType      String    @map("event_type")
  payload        Json
  idempotencyKey String    @unique @map("idempotency_key")
  processed      Boolean   @default(false)
  processedAt    DateTime? @map("processed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([provider, createdAt])
  @@index([processed])
  @@map("webhook_events")
}

model OutboxEvent {
  id            String   @id @default(uuid())
  aggregateId   String   @map("aggregate_id")
  aggregateType String   @map("aggregate_type")
  eventType     String   @map("event_type")
  payload       Json
  status        String   @default("PENDING")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  error         String?
  retryCount    Int      @default(0) @map("retry_count")

  @@index([status, createdAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events_v2")
}

model OfferReservation {
  id                    String            @id @default(uuid())
  offerId               String            @map("offer_id")
  userId                String            @map("user_id")
  quantity              Int               @default(1)
  expiresAt             DateTime          @map("expires_at")
  status                ReservationStatus @default(PENDING)
  idempotencyKey        String?           @unique @map("idempotency_key")
  providerReservationId String?           @map("provider_reservation_id")
  createdAt             DateTime          @default(now()) @map("created_at")
  confirmedAt           DateTime?         @map("confirmed_at")
  user                  User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([offerId])
  @@index([status, expiresAt])
  @@map("offer_reservations")
}

model ServiceAggregate {
  id            String   @id @default(uuid())
  serviceCode   String   @unique @map("service_code")
  serviceName   String   @map("service_name")
  lowestPrice   Decimal  @map("lowest_price") @db.Decimal(8, 2)
  totalStock    BigInt   @map("total_stock")
  countryCount  Int      @map("country_count")
  providerCount Int      @map("provider_count")
  lastUpdatedAt DateTime @default(now()) @map("last_updated_at")

  @@index([lowestPrice])
  @@index([totalStock])
  @@index([serviceName])
  @@map("service_aggregates")
}

model Activation {
  id                   String                   @id @default(uuid())
  userId               String                   @map("user_id")
  state                ActivationState          @default(RESERVED)
  price                Decimal                  @db.Decimal(18, 8)
  providerCost         Decimal                  @default(0.0) @map("provider_cost") @db.Decimal(18, 8)
  profit               Decimal                  @default(0.0) @db.Decimal(18, 8)
  reservedTxId         String?                  @map("reserved_tx_id")
  capturedTxId         String?                  @map("captured_tx_id")
  refundTxId           String?                  @map("refund_tx_id")
  providerActivationId String?                  @map("provider_activation_id")
  providerId           String?                  @map("provider_id")
  serviceName          String                   @map("service_name")
  countryCode          String                   @map("country_code")
  countryName          String?                  @map("country_name")
  operatorId           String?                  @map("operator_id")
  phoneNumber          String?                  @map("phone_number")
  expiresAt            DateTime?                @map("expires_at")
  numberId             String?                  @unique @map("number_id")
  idempotencyKey       String?                  @unique @map("idempotency_key")
  traceId              String?                  @map("trace_id")
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")
  history              ActivationStateHistory[]

  @@index([userId, state])
  @@index([state, expiresAt])
  @@index([state, createdAt])
  @@index([providerId, state])
  @@map("activations")
}

model ActivationStateHistory {
  id            String           @default(uuid())
  activationId  String           @map("activation_id")
  state         ActivationState
  previousState ActivationState? @map("previous_state")
  reason        String?
  metadata      Json?
  traceId       String?          @map("trace_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  activation    Activation       @relation(fields: [activationId], references: [id], onDelete: Cascade)

  @@id([id, createdAt])
  @@index([activationId])
  @@index([createdAt])
  @@map("activation_state_history")
}

model ProviderEvent {
  id              String    @id @default(uuid())
  providerEventId String    @unique @map("provider_event_id")
  providerId      String    @map("provider_id")
  activationId    String?   @map("activation_id")
  eventType       String    @map("event_type")
  payload         Json
  processed       Boolean   @default(false)
  processedAt     DateTime? @map("processed_at")
  receivedAt      DateTime  @default(now()) @map("received_at")

  @@index([activationId])
  @@index([processed])
  @@map("provider_events")
}

model Currency {
  code       String   @id
  name       String
  symbol     String
  rate       Decimal  @db.Decimal(10, 4)
  isBase     Boolean  @default(false) @map("is_base")
  isActive   Boolean  @default(true) @map("is_active")
  autoUpdate Boolean  @default(true) @map("auto_update")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("currencies")
}

model SystemSettings {
  id                     String    @id @default("default")
  baseCurrency           String    @default("USD") @map("base_currency")
  displayCurrency        String    @default("USD") @map("display_currency")
  pointsEnabled          Boolean   @default(false) @map("points_enabled")
  pointsName             String    @default("Points") @map("points_name")
  pointsRate             Decimal   @default(100.0) @map("points_rate")
  paymentsEnabled        Boolean   @default(false) @map("payments_enabled")
  upiProviderMode        String    @default("DISABLED") @map("upi_provider_mode")
  upiApiToken            String?   @map("upi_api_token")
  upiCreateOrderUrl      String?   @map("upi_create_order_url")
  upiCheckStatusUrl      String?   @map("upi_check_status_url")
  upiQrBaseUrl           String?   @map("upi_qr_base_url")
  paytmMerchantId        String?   @map("paytm_merchant_id")
  paytmMerchantKey       String?   @map("paytm_merchant_key")
  paytmWebsite           String?   @map("paytm_website")
  paytmIndustryType      String?   @map("paytm_industry_type")
  paytmChannelId         String?   @map("paytm_channel_id")
  paytmCallbackUrl       String?   @map("paytm_callback_url")
  paytmEnvironment       String    @default("STAGING") @map("paytm_environment")
  depositMinAmount       Decimal   @default(10) @map("deposit_min_amount") @db.Decimal(10, 2)
  depositMaxAmount       Decimal   @default(50000) @map("deposit_max_amount") @db.Decimal(10, 2)
  depositTimeoutMins     Int       @default(30) @map("deposit_timeout_mins")
  maxPendingDeposits     Int       @default(3) @map("max_pending_deposits")
  depositBonusPercent    Decimal   @default(0) @map("deposit_bonus_percent") @db.Decimal(5, 2)
  updatedAt              DateTime  @updatedAt @map("updated_at")
  captchaEnabled         Boolean   @default(true) @map("captcha_enabled")
  cryptoApiBaseUrl       String?   @map("crypto_api_base_url")
  cryptoApiToken         String?   @map("crypto_api_token")
  cryptoProviderMode     String    @default("DISABLED") @map("crypto_provider_mode")
  cryptoUsdtBep20Address String?   @map("crypto_usdt_bep20_address")
  cryptoUsdtTrxAddress   String?   @map("crypto_usdt_trx_address")
  cryptoWebhookSecret    String?   @map("crypto_webhook_secret")
  emailFrom              String?   @map("email_from")
  heartbeatEnabled       Boolean   @default(true) @map("heartbeat_enabled")
  heartbeatIntervalMins  Int       @default(60) @map("heartbeat_interval_mins")
  heartbeatLastRunAt     DateTime? @map("heartbeat_last_run_at")
  inrToUsdRate           Decimal   @default(96.28) @map("inr_to_usd_rate") @db.Decimal(10, 4)
  ratesVersion           Int       @default(1) @map("rates_version")
  smtpHost               String?   @map("smtp_host")
  smtpPass               String?   @map("smtp_pass")
  smtpPort               Int?      @map("smtp_port")
  smtpUser               String?   @map("smtp_user")
  syncBufferPercent      Decimal   @default(2.0) @map("sync_buffer_percent") @db.Decimal(5, 2)

  @@map("system_settings")
}

model ApiKey {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  name        String
  keyHash     String    @unique @map("key_hash")
  prefix      String
  permissions String[]
  tier        ApiTier   @default(FREE)
  rateLimit   Int       @default(60) @map("rate_limit")
  usageCount  BigInt    @default(0) @map("usage_count")
  lastUsedAt  DateTime? @map("last_used_at")
  lastUsedIp  String?   @map("last_used_ip")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  ipWhitelist String[]  @map("ip_whitelist")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prefix])
  @@index([isActive])
  @@map("api_keys")
}

model Webhook {
  id            String            @id @default(uuid())
  userId        String            @map("user_id")
  url           String
  secret        String
  events        String[]
  isActive      Boolean           @default(true) @map("is_active")
  failCount     Int               @default(0) @map("fail_count")
  lastTriedAt   DateTime?         @map("last_tried_at")
  lastSuccessAt DateTime?         @map("last_success_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  deliveries    WebhookDelivery[]
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("webhooks")
}

model WebhookDelivery {
  id           String    @id @default(uuid())
  webhookId    String    @map("webhook_id")
  event        String
  payload      Json
  status       String    @default("pending")
  responseCode Int?      @map("response_code")
  responseBody String?   @map("response_body")
  durationMs   Int?      @map("duration_ms")
  attempts     Int       @default(0)
  nextRetryAt  DateTime? @map("next_retry_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  deliveredAt  DateTime? @map("delivered_at")
  webhook      Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@index([nextRetryAt])
  @@map("webhook_deliveries")
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  ipAddress String?   @map("ip_address")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_resets")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model BannedIcon {
  id          String   @id @default(uuid())
  hash        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("banned_icons")
}

model Coupon {
  id               String             @id @default(uuid())
  code             String             @unique
  type             CouponType
  status           CouponStatus       @default(ACTIVE)
  discountType     String?
  discountValue    Decimal?           @db.Decimal(10, 2)
  giftAmount       Decimal?           @db.Decimal(10, 2)
  maxDiscount      Decimal?           @db.Decimal(10, 2)
  maxUses          Int                @default(1)
  maxUsesPerUser   Int                @default(1)
  currentUses      Int                @default(0)
  minDepositAmount Decimal?           @db.Decimal(10, 2)
  validServices    String[]           @default([])
  newUsersOnly     Boolean            @default(false)
  startsAt         DateTime           @default(now())
  expiresAt        DateTime?
  referrerId       String?            @map("referrer_id")
  referralBonus    Decimal?           @db.Decimal(10, 2)
  name             String?
  description      String?
  createdBy        String?            @map("created_by")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  redemptions      CouponRedemption[]
  referrer         User?              @relation("ReferrerCoupons", fields: [referrerId], references: [id])

  @@index([code])
  @@index([type, status])
  @@index([referrerId])
  @@index([expiresAt])
  @@map("coupons")
}

model CouponRedemption {
  id                String   @id @default(uuid())
  couponId          String   @map("coupon_id")
  userId            String   @map("user_id")
  depositId         String?  @map("deposit_id")
  appliedAmount     Decimal  @db.Decimal(10, 2)
  originalAmount    Decimal? @db.Decimal(10, 2)
  finalAmount       Decimal? @db.Decimal(10, 2)
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  deviceFingerprint String?  @map("device_fingerprint")
  redeemedAt        DateTime @default(now()) @map("redeemed_at")
  coupon            Coupon   @relation(fields: [couponId], references: [id])
  user              User     @relation(fields: [userId], references: [id])

  @@unique([couponId, userId, depositId])
  @@index([userId])
  @@index([couponId])
  @@index([redeemedAt])
  @@map("coupon_redemptions")
}

model VerificationAttempt {
  id          String   @id @default(uuid())
  token       String
  ipAddress   String
  success     Boolean
  attemptedAt DateTime @default(now())
  userId      String?
  user        User?    @relation("VerificationAttemptUser", fields: [userId], references: [id])

  @@index([token])
  @@index([ipAddress])
  @@index([ipAddress, attemptedAt])
  @@index([token, attemptedAt])
  @@map("verification_attempts")
}

enum Role {
  USER
  ADMIN
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum ActivationState {
  INIT
  RESERVED
  ACTIVE
  RECEIVED
  EXPIRED
  CANCELLED
  FAILED
  REFUNDED
}

enum ApiTier {
  FREE
  PRO
  ENTERPRISE
}

enum CouponType {
  PROMO
  GIFT
  REFERRAL
}

enum CouponStatus {
  ACTIVE
  EXPIRED
  DEPLETED
  DISABLED
}
