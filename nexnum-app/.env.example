# ===========================================
# NexNum Environment Variables (Template)
# ===========================================

# ── Database ─────────────────────────────
# Get from: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
DATABASE_URL_DIRECT="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── Redis ────────────────────────────────
# Format: redis://[:password]@host:port
REDIS_URL="redis://:dev_redis_pass@localhost:6379"
REDIS_PASSWORD="dev_redis_pass"

# ── Meilisearch ──────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="dev_master_key"

# ── Authentication & Security ────────────
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
ENCRYPTION_KEY="your-super-secret-encryption-key-change-this"
ADMIN_API_KEY="your-admin-api-key"
NEXTAUTH_SECRET="your-nextauth-secret-key"
SMS_FINGERPRINT_SECRET="your-sms-fingerprint-secret"
FINGERPRINT_SALT="change-this-to-rotate-all-device-fingerprints"
CSRF_SECRET="your-csrf-secret"

# ── App URLs ─────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"

# ── Monitoring & Alerts ──────────────────
ALERT_WEBHOOK_SECRET="change-this-to-a-secure-random-string"
METRICS_SCRAPE_TOKEN="nexnum-metrics-token-dev-8821"
CRON_SECRET="your-cron-secret-key"

# ── Sentry (Optional) ────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ── Telegram Notifications ───────────────
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrSTUvwxYZ"
TELEGRAM_ADMIN_CHANNEL="-1001234567890"

# ── Email SMTP ───────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
FROM_EMAIL='"NexNum" <noreply@nexnum.com>'

# ── Web Push (VAPID) ─────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:support@yourdomain.com"

# ── Google OAuth ─────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── SMS Provider API Keys ────────────────
FIVESIM_API_KEY=""
HERO_SMS_API_KEY=""
SMSBOWER_API_KEY=""
GRIZZLYSMS_API_KEY=""
ONLINESIM_API_KEY=""
GEMINI_API_KEYS="key1,key2,key3"

# ── Image Upload API Keys ────────────────
FREEIMAGE_API_KEY=""
IMGE_API_KEY=""

# ── CAPTCHA ──────────────────────────────
NEXT_PUBLIC_HCAPTCHA_SITEKEY=""
HCAPTCHA_SECRET=""
NEXT_PUBLIC_RECAPTCHA_SITEKEY=""
RECAPTCHA_SECRET=""

# ── UPI Payment Gateway ──────────────────
UPI_PROVIDER_MODE="DISABLED"
UPI_API_TOKEN=""
UPI_CREATE_ORDER_URL=""
UPI_CHECK_STATUS_URL=""
UPI_QR_BASE_URL=""
UPI_WEBHOOK_URL=""
UPI_ORDER_TIMEOUT_MINUTES="30"
UPI_MIN_AMOUNT="10"
UPI_MAX_AMOUNT="50000"

# ===========================================
# Limits & Timeouts
# ===========================================

# ── Limits ───────────────────────────────
DAILY_SPEND_LIMIT="100"
MAX_PURCHASE_AMOUNT="50"
MIN_PURCHASE_AMOUNT="0.01"
MAX_ACTIVE_NUMBERS="10"
MAX_SMS_PER_ACTIVATION="5"

# ── Timeouts (milliseconds) ──────────────
RESERVATION_TTL_MS="300000"
MIN_REFUND_AGE_MS="120000"
STUCK_THRESHOLD_MS="600000"
PROVIDER_TIMEOUT_MS="15000"
NUMBER_LIFETIME_MS="1200000"
GRACE_PERIOD_MS="60000"

# ── Workers ──────────────────────────────
WORKER_BATCH_SIZE="50"
WORKER_CONCURRENCY="10"
POLL_INTERVAL_MS="30000"
RECONCILE_INTERVAL_MS="60000"
CLEANUP_INTERVAL_MS="120000"

# ── Feature Flags ────────────────────────
ENABLE_MOCK_PROVIDER="false"
DEBUG="false"
MAINTENANCE_MODE="false"
ENABLE_SMS_FINGERPRINTING="true"
ENABLE_HEALTH_MONITORING="true"
NEXT_PUBLIC_SOCKET_ENABLED="true"
# Public URL for socket.io client connections (used by browser)
NEXT_PUBLIC_SOCKET_URL="wss://socket.nexnum.tech"
OUTBOX_WORKER_ENABLED="true"

# ── Pricing ──────────────────────────────
DEFAULT_MARKUP_PERCENT="20"
MIN_PRICE_USD="0.10"
MAX_PRICE_USD="50.00"
PRICE_PRECISION="2"

# ── Deposit Exchange Rates ────────────────
EXCHANGE_RATE_USD="1"
EXCHANGE_RATE_INR="96.28"
EXCHANGE_RATE_RUB="72.77"
EXCHANGE_RATE_EUR="0.86"
EXCHANGE_RATE_GBP="0.74"
EXCHANGE_RATE_CNY="6.80"

# ── Deposit Taxes and Markup ──────────────
DEPOSIT_TAX_PERCENT="0.0"
DEPOSIT_MARKUP_PERCENT="0.0"

# ── Security ─────────────────────────────
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="100"
TRUST_PROXY="true"

# ── Prisma ───────────────────────────────
NEXT_TELEMETRY_DISABLED="1"
PRISMA_CLIENT_ENGINE_TYPE="library"
PRISMA_CLI_QUERY_ENGINE_TYPE="library"
